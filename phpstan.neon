parameters:
    level: 8
    paths:
        - src/
    bootstrapFiles:
        - vendor/szepeviktor/phpstan-wordpress/bootstrap.php
    treatPhpDocTypesAsCertain: false
    stubFiles:
        - phpstan/stubs/wpdb.stub.php
    # Row is #[AllowDynamicProperties] by design: its properties ARE the table's
    # columns, unknowable statically. Declare that so property reads type-check.
    universalObjectCratesClasses:
        - BerlinDB\Database\Kern\Row

